{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "short_name": "JobbPiloten",
  "version": "0.2.3",
  "description": "__MSG_extDescription__",
  "default_locale": "sv",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "JobbPiloten Auto-Fill",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "all_frames": true,
      "js": ["content.js"]
    },
    {
      "matches": [
        "https://mail.google.com/mail/u/*",
        "https://outlook.live.com/mail/*",
        "https://outlook.office.com/mail/*"
      ],
      "run_at": "document_idle",
      "all_frames": false,
      "js": ["content-email.js"]
    }
  ],
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "windows"
  ],
  "host_permissions": [
    "https://jobbpiloten.se/*",
    "https://*.vercel.app/*",
    "https://*.preview.emergentagent.com/*",
    "https://*.preview.app.github.dev/*",
    "http://localhost:*/*",
    "https://mail.google.com/*",
    "https://outlook.live.com/*",
    "https://outlook.office.com/*",
    "https://*.arbetsformedlingen.se/*",
    "https://*.blocket.se/*"
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'none'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src 'self' https://jobbpiloten.se https://*.vercel.app https://*.preview.emergentagent.com https://*.preview.app.github.dev http://localhost:* https://mail.google.com https://outlook.live.com https://outlook.office.com https://*.arbetsformedlingen.se https://*.blocket.se; object-src 'none'; form-action 'none'; frame-ancestors 'none'"
  }
}
