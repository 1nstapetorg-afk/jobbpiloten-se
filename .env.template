# JobbPiloten Environment Template
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# See .gitignore for the ignore rules.
#
# SENTINEL FORMAT: replace the `__YOUR_*__` words inside each line
# with the actual value. The double-underscore + literal word keeps
# the placeholder grep + machine-readable (a future `sed s/__YOUR_.*__//g`
# on this file would strip them safely without truncating prefixes).

# ===== PRIVATE (server-only — NEVER prefix with NEXT_PUBLIC_) =====
# These values must NEVER ship to the client bundle. They are read
# only on the server (Next.js route handlers, lib/groq.js, lib/auth.js).
# If you accidentally rename one to NEXT_PUBLIC_*, the build will still
# succeed but the secret will be publicly visible to every visitor.

# MongoDB Atlas (or self-hosted) connection string.
MONGO_URL=mongodb+srv://__YOUR_DB_USER__:__YOUR_DB_PASSWORD__@__YOUR_CLUSTER__.mongodb.net/__YOUR_DB_NAME__?retryWrites=true&w=majority

# MongoDB database name.
DB_NAME=jobbpiloten

# Groq API key (https://console.groq.com). Free tier is fine for soft-launch.
GROQ_API_KEY=gsk___YOUR_GROQ_KEY__

# Clerk server-side secret (https://dashboard.clerk.com).
CLERK_SECRET_KEY=sk_test___YOUR_CLERK_SECRET__

# Stripe server-side secret (https://dashboard.stripe.com) — only if payments are wired up.
STRIPE_SECRET_KEY=sk_test___YOUR_STRIPE_SECRET__

# Web Push VAPID private key — generate via `web-push generate-vapid-keys`.
VAPID_PRIVATE_KEY=__YOUR_VAPID_PRIVATE__

# ===== PUBLIC (inlined at build time — safe to expose in client bundle) =====
# Next.js inlines any `NEXT_PUBLIC_*` env var into the JavaScript bundle
# at build time. The values are visible to every visitor — only put
# things here that are safe to expose (publishable keys, public URLs).

# Public base URL of the deployed app. Dev default is localhost:3000;
# production must point at https://jobbpiloten.se.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Clerk publishable key (safe to expose).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test___YOUR_CLERK_PUBLISHABLE__

# Stripe publishable key (safe to expose) — only if payments are wired up.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test___YOUR_STRIPE_PUBLISHABLE__

# Web Push VAPID public key (safe to expose) — sent to the browser so it
# can subscribe to push notifications.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=__YOUR_VAPID_PUBLIC__
