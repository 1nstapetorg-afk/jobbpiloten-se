# JobbPiloten Environment Template
# Copy this file to .env and fill in real values. NEVER commit .env
# or any of its variants (.env.local, .env.production, etc.) to git.
# See .gitignore for the ignore rules.
#
# SENTINEL FORMAT: every value below is the placeholder `__YOUR_*__`
# (no vendor prefix like `sk_test_` or `gsk_` — drop your real value
# over the ENTIRE placeholder). The double-underscore convention
# keeps the placeholder grep + machine-readable: a future
# `sed s/__YOUR_.*__//g` on this file strips them safely.

# ===== PRIVATE (server-only — NEVER prefix with NEXT_PUBLIC_) =====
# These values must NOT ship to the client bundle. Read only on the
# server (Next.js route handlers, lib/groq.js, lib/auth.js). If you
# accidentally rename one to NEXT_PUBLIC_*, the build still succeeds
# but the secret becomes publicly visible to every visitor.

# MongoDB Atlas (or self-hosted) connection string.
MONGO_URL=mongodb+srv://__YOUR_DB_USER__:__YOUR_DB_PASSWORD__@__YOUR_CLUSTER__.mongodb.net/__YOUR_DB_NAME__?retryWrites=true&w=majority

# MongoDB database name.
DB_NAME=jobbpiloten

# --- LLM provider keys (intentionally OMITTED from this template) ---
# lib/groq.js's pickProvider() walks `LLM_KEY_NAMES` (at module
# scope) and uses `process.env[first-populated-name]` as the
# active API key. The 4 priority slots are:
#   GROQ_API_KEY       - canonical soft-launch provider
#   OPENAI_API_KEY     - direct OpenAI access
#   EMERGENT_LLM_KEY   - Emergent proxy (see comment block in lib/groq.js)
#   OPENROUTER_API_KEY - multi-provider router
# IMPORTANT: although pickProvider() walks the table, each
# provider branch in lib/groq.js is currently COMMENTED OUT —
# none of the 4 keys actually consume env values today. Adding
# a populated key would activate the walker, but the matching
# OpenAI-client branch in lib/groq.js has no working code path,
# so LLM calls would silently fall back to no-AI templates.
# To enable ONE provider, add ONE of these lines to your real
# .env AFTER uncommenting the matching branch in lib/groq.js:
#   GROQ_API_KEY=gsk___your_actual_groq_key
#   OPENAI_API_KEY=sk-___your_actual_openai_key
#   EMERGENT_LLM_KEY=___your_actual_emergent_key
#   OPENROUTER_API_KEY=sk-or-___your_actual_openrouter_key
# (Do NOT add these placeholder lines here — keep all 4 keys absent.)

# --- LLM model override (lib/groq.js ACTIVE runtime reads) ---
# Both keys below are safe to set: they're read at runtime with
# hardcoded fallbacks, so an unset value uses the default model.
# Overriding here lets a maintainer switch models without code
# deploy (e.g. for cost / latency tuning during soft-launch).
EMERGENT_MODEL=gpt-4o-mini
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Clerk server-side secret (https://dashboard.clerk.com).
CLERK_SECRET_KEY=__YOUR_CLERK_SECRET_KEY__

# Stripe server-side secret (https://dashboard.stripe.com) — only if payments wired up.
STRIPE_SECRET_KEY=__YOUR_STRIPE_SECRET_KEY__

# Web Push VAPID private key — generate via `web-push generate-vapid-keys`.
VAPID_PRIVATE_KEY=__YOUR_VAPID_PRIVATE_KEY__

# ===== PUBLIC (inlined at build time by Next.js — safe in client bundle) =====
# Next.js inlines any `NEXT_PUBLIC_*` env var into the JavaScript
# bundle at build time. The values are visible to every visitor —
# only put things here that are safe to expose (publishable keys,
# public URLs).

# Public base URL of the deployed app. Dev default is localhost:3000;
# production must point at https://jobbpiloten.se.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Clerk publishable key (safe to expose).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=__YOUR_CLERK_PUBLISHABLE_KEY__

# Stripe publishable key (safe to expose) — only if payments wired up.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=__YOUR_STRIPE_PUBLISHABLE_KEY__

# Web Push VAPID public key (safe to expose) — sent to the browser so
# it can subscribe to push notifications.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=__YOUR_VAPID_PUBLIC_KEY__
