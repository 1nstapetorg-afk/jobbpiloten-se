# JobbPiloten Environment Template
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# See .gitignore for the ignore rules.
#
# SENTINEL FORMAT: every value below is the placeholder `__YOUR_*__` (no
# vendor prefix like `sk_test_` or `gsk_` — drop your real value over the
# ENTIRE placeholder). The double-underscore + literal word keeps the
# placeholder grep + machine-readable: a future `sed s/__YOUR_.*__//g`
# on this file strips them safely without truncating vendor prefixes.

# ===== PRIVATE (server-only — NEVER prefix with NEXT_PUBLIC_) =====
# These values must NOT ship to the client bundle. Read only on the
# server (Next.js route handlers, lib/groq.js, lib/auth.js). If you
# accidentally rename one to NEXT_PUBLIC_*, the build still succeeds
# but the secret becomes publicly visible to every visitor.

# MongoDB Atlas (or self-hosted) connection string.
MONGO_URL=mongodb+srv://__YOUR_DB_USER__:__YOUR_DB_PASSWORD__@__YOUR_CLUSTER__.mongodb.net/__YOUR_DB_NAME__?retryWrites=true&w=majority

# MongoDB database name.
DB_NAME=jobbpiloten

# --- LLM providers (lib/groq.js precedence: GROQ → OPENAI → EMERGENT) ---
# Drop YOUR key over the placeholder for EVERY provider you have a key
# for. The runtime checks each provider in order; missing keys fall
# through to a fallback template so an empty value is safe.

GROQ_API_KEY=__YOUR_GROQ_API_KEY__
OPENAI_API_KEY=__YOUR_OPENAI_API_KEY__
EMERGENT_LLM_KEY=__YOUR_EMERGENT_LLM_KEY__

# Clerk server-side secret (https://dashboard.clerk.com).
CLERK_SECRET_KEY=__YOUR_CLERK_SECRET_KEY__

# Clerk webhook signing secret (if webhooks are wired up; else leave blank).
CLERK_WEBHOOK_SECRET=__YOUR_CLERK_WEBHOOK_SECRET__

# Stripe server-side secret (https://dashboard.stripe.com) — only if payments wired up.
STRIPE_SECRET_KEY=__YOUR_STRIPE_SECRET_KEY__

# Web Push VAPID private key — generate via `web-push generate-vapid-keys`.
VAPID_PRIVATE_KEY=__YOUR_VAPID_PRIVATE_KEY__

# ===== PUBLIC (inlined at build time by Next.js — safe in client bundle) =====
# Next.js inlines any `NEXT_PUBLIC_*` env var into the JavaScript
# bundle at build time. The values are visible to every visitor —
# only put things here that are safe to expose (publishable keys,
# public URLs).

# Public base URL of the deployed app. Dev default is localhost:3000;
# production must point at https://jobbpiloten.se.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Clerk publishable key (safe to expose).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=__YOUR_CLERK_PUBLISHABLE_KEY__

# Stripe publishable key (safe to expose) — only if payments wired up.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=__YOUR_STRIPE_PUBLISHABLE_KEY__

# Web Push VAPID public key (safe to expose) — sent to the browser so
# it can subscribe to push notifications.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=__YOUR_VAPID_PUBLIC_KEY__
